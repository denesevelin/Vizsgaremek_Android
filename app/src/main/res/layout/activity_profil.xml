<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Profil">

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:id="@+id/relativeLayoutProfil">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profil"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:id="@+id/textViewProfil"/>

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/tesztprofilkep"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="70dp"
            android:id="@+id/imageViewProfilkepProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/imageViewProfilkepProfil"
            android:layout_marginLeft="70dp"
            android:layout_marginTop="120dp"
            android:text="Teszt Ella"
            android:id="@+id/textViewNevProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/imageViewProfilkepProfil"
            android:layout_below="@+id/textViewNevProfil"
            android:layout_marginLeft="70dp"
            android:layout_marginTop="20dp"
            android:text="teszt.ella1983"
            android:id="@+id/textViewFelhasznalonevProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/imageViewProfilkepProfil"
            android:layout_marginLeft="30dp"
            android:text="+36301234567"
            android:id="@+id/textViewTelefonszamProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewTelefonszamProfil"
            android:layout_marginLeft="30dp"
            android:text="teszt.ella@gmail.com"
            android:id="@+id/textViewEmailProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewEmailProfil"
            android:layout_marginLeft="30dp"
            android:text="Budapest"
            android:id="@+id/textViewTelepulesProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewTelepulesProfil"
            android:layout_marginLeft="30dp"
            android:text="1033 Teszt utca 124. 5/36."
            android:layout_marginBottom="10dp"
            android:id="@+id/textViewCimProfil"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewCimProfil"
            android:layout_marginLeft="30dp"
            android:text="Pontszám: "
            android:textStyle="bold"
            android:id="@+id/textViewPontszamProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewCimProfil"
            android:layout_toEndOf="@+id/textViewPontszamProfil"
            android:layout_marginLeft="30dp"
            android:text="5"
            android:textStyle="bold"
            android:id="@+id/textViewKonkretPontszamProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewPontszamProfil"
            android:layout_marginLeft="30dp"
            android:text="Díjaim: "
            android:textStyle="bold"
            android:layout_marginBottom="10dp"
            android:id="@+id/textViewDijProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/textViewDijProfil"
            android:layout_marginLeft="30dp"
            android:text="Hirdetések amikre jelentkeztem: "
            android:layout_marginBottom="10dp"
            android:id="@+id/textViewJelentkeztemProfil"/>

        <ImageButton
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/kutyasetaltatas"
            android:layout_below="@+id/textViewJelentkeztemProfil"
            android:id="@+id/imageButtonJelentkeztemProfil"/>

        <ImageButton
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/korhaz"
            android:layout_below="@+id/textViewJelentkeztemProfil"
            android:layout_toEndOf="@+id/imageButtonJelentkeztemProfil"
            android:id="@+id/imageButton2JelentkeztemProfil"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/imageButtonJelentkeztemProfil"
            android:layout_marginLeft="30dp"
            android:text="Saját hirdetéseim: "
            android:layout_marginBottom="10dp"
            android:id="@+id/textViewHirdeteseimProfil"/>

        <ImageButton
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/kutyasetaltatas"
            android:layout_below="@+id/textViewHirdeteseimProfil"
            android:id="@+id/imageButtonHirdetesemProfil"/>

        <ImageButton
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/korhaz"
            android:layout_below="@+id/textViewHirdeteseimProfil"
            android:layout_toEndOf="@+id/imageButtonHirdetesemProfil"
            android:id="@+id/imageButton2HirdetesemProfil"/>
        <Button
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:text="Törlés"
            android:textSize="10dp"
            android:layout_marginLeft="10dp"
            android:layout_below="@+id/imageButtonHirdetesemProfil"
            android:id="@+id/buttonHirdetesTorleseProfil"/>
        <Button
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:text="Törlés"
            android:textSize="10dp"
            android:layout_marginLeft="20dp"
            android:layout_toEndOf="@+id/buttonHirdetesTorleseProfil"
            android:layout_below="@+id/imageButton2HirdetesemProfil"
            android:id="@+id/button2HirdetesTorleseProfil"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/buttonHirdetesTorleseProfil"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="20dp"
            android:text="Profil módosítása"
            android:id="@+id/buttonProfilModositasProfil"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/buttonHirdetesTorleseProfil"
            android:layout_toEndOf="@+id/buttonProfilModositasProfil"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="20dp"
            android:text="Profil törlése"
            android:id="@+id/buttonProfilTorlesProfil"/>

    </RelativeLayout>

</ScrollView>